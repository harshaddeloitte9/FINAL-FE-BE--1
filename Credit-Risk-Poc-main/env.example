# LLM provider configuration for Agent2's conceptual-validation LLM check
# (agent2.py: check_documents_with_llm / llm_providers.py).
#
# Copy this file to `.env` (same directory as agent2.py) and fill in the
# values below. Nothing is hardcoded in application code — these are read
# from the environment at request time.

# --- Primary provider: Deloitte Agent ---------------------------------------
# Base URL of the Deloitte Agent completion endpoint.
DELOITTE_AGENT_URL=
# API key / bearer token for the Deloitte Agent.
DELOITTE_API_KEY=
# Optional. Request timeout in seconds (default 120 if unset). Conceptual
# Soundness has more rules per batch than Data Validation, so raise this
# further if you still see "LLM check unavailable" / empty-response errors.
DELOITTE_TIMEOUT_SECONDS=120

# --- Fallback provider: Ollama -----------------------------------------------
# Used automatically if the Deloitte Agent is unreachable, times out, or
# returns an HTTP error — or if DELOITTE_AGENT_URL is left blank above.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# Optional. Request timeout in seconds (default 180 if unset).
OLLAMA_TIMEOUT_SECONDS=180
